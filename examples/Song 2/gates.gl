(def kick-gate-1
  (p (then
    (times 4[0 0 0 0 1 0])
    (times 4[1 0 0 1 0 0]))))
  
(def hat-gate-1
  (p (then
    (times 4[1 0 1 0 1 0])
    (times 4[1 1 1 [1 0 0 1] 0 1])
    (times 4[1 0 1 [0 0 0 1] 1 0]))))
  
(def snare-gate-1
  (p (then
    (times 8[0 0 0 0 0 0])
    (times 2[0 0 0 0 0 1])
    (times 2[0 0 1 0 0 0]))))
    
(def breath-gate-1
  (p (then
    (times 8[1 1 1 1 1 1])
    (times 8[1 0 1 0 1 0]))))
    
(def breath-gate-2
  (p (then
    (times 8[1_6])
    (times 8[1_6]))))